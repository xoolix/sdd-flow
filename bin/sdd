#!/usr/bin/env bash
set -euo pipefail

# SDD — Spec Driven Development CLI
# Initializes any project with the SDD workflow for Claude Code.

SDD_HOME="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")/.." && pwd)"
VERSION="2.0.0"

# ─── Core SDD skills (these go to global ~/.claude/skills/) ──────
CORE_SKILLS="new-feature new-quick-feature new-fix plan-feature implement-task simplify-code review-feature archive-feature research-spike sdd-new sdd-next sdd-auto init-project build-registry _shared"

# ─── helpers ───────────────────────────────────────────────────────

log()  { printf "\033[0;34m▸\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m✔\033[0m %s\n" "$*"; }
warn() { printf "\033[0;33m⚠\033[0m %s\n" "$*"; }
err()  { printf "\033[0;31m✖\033[0m %s\n" "$*" >&2; }

is_core_skill() {
  local name="$1"
  for core in $CORE_SKILLS; do
    [ "$name" = "$core" ] && return 0
  done
  return 1
}

link_or_copy() {
  local src="$1" dst="$2" mode="${3:-link}"
  mkdir -p "$(dirname "$dst")"
  if [ "$mode" = "copy" ]; then
    cp -R "$src" "$dst"
  else
    ln -sfn "$src" "$dst"
  fi
}

# True if the project at $1 (default pwd) was installed in --copy mode.
# Primary signal: `.specify/.sdd-copy-install` sentinel file, written by `sdd init --copy`.
# Legacy fallback: `.specify/templates` is a regular dir that resolves to a path OUTSIDE SDD_HOME
# (real-path check — `cp -R` on a symlink source may produce either symlink or copy depending
# on platform; the sentinel makes intent explicit).
is_copy_install() {
  local target="${1:-$(pwd)}"
  [ -f "$target/.specify/.sdd-copy-install" ] && return 0
  # Legacy fallback for projects that predate the sentinel
  [ -d "$target/.specify/templates" ] && [ ! -L "$target/.specify/templates" ] || return 1
  # Confirm via real-path: if readlink resolves templates into SDD_HOME, it's a symlink install
  local real_tpl
  real_tpl="$(cd "$target/.specify/templates" 2>/dev/null && pwd -P)" || return 1
  case "$real_tpl" in
    "$SDD_HOME"/*) return 1 ;;
    *) return 0 ;;
  esac
}

# Ensure a path is present in the project's .gitignore. No-op if already listed.
# Creates .gitignore if missing. Matches whole-line entries.
ensure_gitignored() {
  local target="$1" path="$2"
  local gi="$target/.gitignore"
  [ -f "$gi" ] || touch "$gi"
  if ! grep -Fxq "$path" "$gi" 2>/dev/null; then
    printf '%s\n' "$path" >> "$gi"
    ok "Added $path to .gitignore"
  fi
}

# Gitignore the two machine-local CLAUDE.md artifacts (symlink + its migration backup).
# Called ONLY from symlink-mode branches — --copy installs commit CLAUDE.md to git.
gitignore_claude_md_artifacts() {
  local target="$1"
  ensure_gitignored "$target" ".claude/CLAUDE.md"
  ensure_gitignored "$target" ".claude/CLAUDE.md.backup"
}

usage() {
  cat <<EOF
sdd — Spec Driven Development CLI (v${VERSION})

Usage:
  sdd init [--copy]              Initialize SDD in the current directory
  sdd init --global              Install core SDD skills to ~/.claude/skills/ (one time)
  sdd update                     Re-sync symlinks (skills, templates, CLAUDE.md);
                                 migrate pre-symlink CLAUDE.md to symlink with backup
  sdd doctor                     Verify SDD setup is healthy
  sdd base-branch [feature-id]   Resolve the base branch for scope computations
                                 (Layer 1: sidecar, Layer 2: git.md config, Layer 3: auto-detect)
  sdd status [feature-id]        Emit JSON describing a feature's SDD phase and state
  sdd help                       Show this help

Options for 'init':
  --copy     Copy files instead of symlinking (standalone, no auto-updates)
  --global   Install core SDD skills globally to ~/.claude/skills/

Layers:
  ~/.claude/skills/        Core SDD skills (shared across all projects)
  .claude/skills/          Project-specific skills (React, Go, etc.)
  .claude/rules/           Project conventions + model overrides
  .claude/CLAUDE.md        Symlink to SDD_HOME (auto-updates on SDD git pull)

After 'sdd init', start Claude Code and run /init-project to auto-generate
architecture docs and detect project conventions.
EOF
}

# ─── init --global ────────────────────────────────────────────────

cmd_init_global() {
  local mode="${1:-link}"

  log "Installing core SDD skills to ~/.claude/skills/ (mode: $mode)"

  mkdir -p "$HOME/.claude/skills"

  # Install core skills
  for skill in $CORE_SKILLS; do
    local src="$SDD_HOME/.claude/skills/$skill"
    if [ -d "$src" ] || [ -f "$src" ]; then
      link_or_copy "$src" "$HOME/.claude/skills/$skill" "$mode"
      ok "Core skill: $skill"
    else
      warn "Core skill not found in repo: $skill"
    fi
  done

  # Install templates globally
  mkdir -p "$HOME/.specify"
  link_or_copy "$SDD_HOME/.specify/templates" "$HOME/.specify/templates" "$mode"
  ok "Templates installed to ~/.specify/templates/"

  echo ""
  ok "Global SDD core installed!"
  echo ""
  log "Now run 'sdd init' inside each project to set up project-specific files."
}

# ─── init (project) ──────────────────────────────────────────────

cmd_init() {
  local mode="link"
  local global=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --copy) mode="copy"; shift ;;
      --global) global=true; shift ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done

  if $global; then
    cmd_init_global "$mode"
    return
  fi

  local target
  target="$(pwd)"

  if [ "$target" = "$SDD_HOME" ]; then
    err "Cannot init inside the SDD boilerplate repo itself."
    exit 1
  fi

  # Check if global core is installed
  if [ ! -d "$HOME/.claude/skills/sdd-next" ] && [ ! -L "$HOME/.claude/skills/sdd-next" ]; then
    warn "Core SDD skills not found in ~/.claude/skills/"
    log "Installing globally first..."
    cmd_init_global "$mode"
    echo ""
  fi

  log "Initializing SDD project in $target"

  # ── Project-specific skills directory ──
  mkdir -p "$target/.claude/skills"

  # Install architecture-map (project-specific — each repo has its own)
  local arch_src="$SDD_HOME/.claude/skills/architecture-map"
  if [ -d "$arch_src" ]; then
    if [ ! -d "$target/.claude/skills/architecture-map" ] && [ ! -L "$target/.claude/skills/architecture-map" ]; then
      cp -R "$arch_src" "$target/.claude/skills/architecture-map"
      ok "Created .claude/skills/architecture-map/ (project-specific)"
    else
      warn "Skipped architecture-map (already exists)"
    fi
  fi

  # ── Templates (symlink to global if available, else from SDD_HOME) ──
  mkdir -p "$target/.specify"
  if [ -d "$HOME/.specify/templates" ] || [ -L "$HOME/.specify/templates" ]; then
    link_or_copy "$HOME/.specify/templates" "$target/.specify/templates" "$mode"
  else
    link_or_copy "$SDD_HOME/.specify/templates" "$target/.specify/templates" "$mode"
  fi
  ok "Templates installed"

  # Mark --copy installs with an explicit sentinel so is_copy_install() is reliable
  # regardless of what cp -R produces on a symlinked source.
  if [ "$mode" = "copy" ]; then
    : > "$target/.specify/.sdd-copy-install"
  fi

  # ── Scripts (shared) ──
  if [ -d "$SDD_HOME/.specify/scripts" ]; then
    link_or_copy "$SDD_HOME/.specify/scripts" "$target/.specify/scripts" "$mode"
    ok "Scripts installed"
  fi

  # ── Rules (project-specific — always copy, never overwrite existing) ──
  mkdir -p "$target/.claude/rules"
  for rule_file in "$SDD_HOME/.claude/rules"/*.md; do
    local rule_name
    rule_name="$(basename "$rule_file")"
    if [ -f "$target/.claude/rules/$rule_name" ]; then
      warn "Skipped .claude/rules/$rule_name (already exists)"
    else
      cp "$rule_file" "$target/.claude/rules/$rule_name"
      ok "Created .claude/rules/$rule_name"
    fi
  done

  # ── Agents (project-local copies, never overwrite) ──
  # Native sub-agents are discovered by Claude Code at session init from .claude/agents/*.md.
  # They declare model/tools/context in frontmatter. Skill routers in .claude/skills/*/SKILL.md
  # delegate to them via Agent tool (subagent_type: "sdd-<phase>"). See feature 008.
  if [ -d "$SDD_HOME/.claude/agents" ]; then
    mkdir -p "$target/.claude/agents"
    for agent_file in "$SDD_HOME/.claude/agents"/sdd-*.md; do
      [ -f "$agent_file" ] || continue
      local agent_name
      agent_name="$(basename "$agent_file")"
      if [ -f "$target/.claude/agents/$agent_name" ]; then
        warn "Skipped .claude/agents/$agent_name (already exists)"
      else
        cp "$agent_file" "$target/.claude/agents/$agent_name"
        ok "Created .claude/agents/$agent_name"
      fi
    done
  fi

  # ── CLAUDE.md (symlink by default for auto-updates, cp on --copy) ──
  # -e tests if the target exists (follows symlinks). A broken symlink → -e false, -L true.
  # We repair broken symlinks rather than silently skipping them.
  if [ -e "$target/.claude/CLAUDE.md" ]; then
    warn "Skipped .claude/CLAUDE.md (already exists)"
  else
    if [ -L "$target/.claude/CLAUDE.md" ]; then
      rm "$target/.claude/CLAUDE.md"
      log "Removed broken CLAUDE.md symlink"
    fi
    link_or_copy "$SDD_HOME/.claude/CLAUDE.md" "$target/.claude/CLAUDE.md" "$mode"
    if [ "$mode" = "copy" ]; then
      ok "Created .claude/CLAUDE.md (copy — standalone, no auto-updates)"
    else
      ok "Created .claude/CLAUDE.md (symlink → SDD_HOME, auto-updates on git pull)"
      gitignore_claude_md_artifacts "$target"
    fi
  fi

  # ── settings.local.json (never overwrite) ──
  if [ -f "$target/.claude/settings.local.json" ]; then
    warn "Skipped .claude/settings.local.json (already exists)"
  else
    if [ -f "$SDD_HOME/.claude/settings.local.json" ]; then
      cp "$SDD_HOME/.claude/settings.local.json" "$target/.claude/settings.local.json"
      ok "Created .claude/settings.local.json"
    fi
  fi

  # ── Directory structure ──
  mkdir -p "$target/specs" "$target/research" "$target/docs/adr" "$target/docs/architecture"
  ok "Created specs/, research/, docs/adr/, docs/architecture/"

  echo ""
  ok "SDD project initialized!"
  echo ""
  log "Structure:"
  echo "  ~/.claude/skills/         ← Core SDD skills (global, shared)"
  echo "  .claude/skills/           ← Project skills (add React, Go, etc. here)"
  echo "  .claude/rules/            ← Project conventions"
  echo "  .claude/CLAUDE.md         ← Orchestrator config"
  echo ""
  log "Next steps:"
  echo "  1. Open Claude Code in $target"
  echo "  2. Run /init-project to auto-detect architecture and conventions"
  echo "  3. Add project skills to .claude/skills/ (React, Python, etc.)"
  echo "  4. Run /build-registry to generate compact rules from your skills"
  echo "  5. Start working: /sdd-new \"your idea\""
  echo ""
}

# ─── update ────────────────────────────────────────────────────────

cmd_update() {
  local target
  target="$(pwd)"

  # Protection: refuse to update inside the SDD boilerplate repo itself.
  # Running `sdd update` with target == SDD_HOME creates self-referential (circular)
  # symlinks for CLAUDE.md. Observed in feature 008 dev cycle — caused ELOOP.
  if [ "$target" = "$SDD_HOME" ]; then
    err "Cannot update inside the SDD boilerplate repo itself."
    exit 1
  fi

  log "Updating SDD"

  # Update global core skills
  log "Updating global core skills..."
  for skill in $CORE_SKILLS; do
    local global_skill="$HOME/.claude/skills/$skill"
    if [ -L "$global_skill" ]; then
      ln -sfn "$SDD_HOME/.claude/skills/$skill" "$global_skill"
      ok "Updated global: $skill"
    elif [ -d "$global_skill" ]; then
      warn "Skipped global $skill (not a symlink — was copied with --copy)"
    else
      ln -sfn "$SDD_HOME/.claude/skills/$skill" "$global_skill"
      ok "Added global: $skill"
    fi
  done

  # Update project templates
  if [ -d "$target/.specify" ]; then
    if [ -L "$target/.specify/templates" ]; then
      if [ -d "$HOME/.specify/templates" ] || [ -L "$HOME/.specify/templates" ]; then
        ln -sfn "$HOME/.specify/templates" "$target/.specify/templates"
      else
        ln -sfn "$SDD_HOME/.specify/templates" "$target/.specify/templates"
      fi
      ok "Updated templates"
    else
      warn "Skipped templates (not a symlink)"
    fi
  fi

  # ── CLAUDE.md: refresh symlink or migrate pre-symlink copy ──
  # Respect --copy installs: don't force-migrate when the project opted out.
  local claude_md="$target/.claude/CLAUDE.md"
  if is_copy_install "$target"; then
    if [ -f "$claude_md" ] && [ ! -L "$claude_md" ]; then
      warn "Skipped CLAUDE.md migration (--copy install detected)"
    elif [ -L "$claude_md" ] && [ ! -e "$claude_md" ]; then
      # --copy install with a broken symlink (unusual state — user likely replaced manually)
      rm "$claude_md"
      cp "$SDD_HOME/.claude/CLAUDE.md" "$claude_md"
      ok "Repaired broken CLAUDE.md (copy — standalone install)"
    elif [ ! -e "$claude_md" ] && [ ! -L "$claude_md" ]; then
      # --copy install but CLAUDE.md is absent — restore as copy (NOT symlink; respects --copy)
      cp "$SDD_HOME/.claude/CLAUDE.md" "$claude_md"
      ok "Restored missing CLAUDE.md (copy — standalone install)"
    fi
    # --copy: do NOT auto-gitignore (users of this mode legitimately track CLAUDE.md in git)
  elif [ -L "$claude_md" ] && [ -e "$claude_md" ]; then
    ln -sfn "$SDD_HOME/.claude/CLAUDE.md" "$claude_md"
    ok "Refreshed CLAUDE.md symlink"
    gitignore_claude_md_artifacts "$target"
  elif [ -L "$claude_md" ]; then
    # Broken OR circular symlink — repair by replacing target.
    # Circular case: readlink returns a path that resolves back to $claude_md (ELOOP).
    # Both cases: [ -L true ] && [ -e false ]. Same fix for both.
    rm "$claude_md"
    ln -sfn "$SDD_HOME/.claude/CLAUDE.md" "$claude_md"
    ok "Repaired broken/circular CLAUDE.md symlink"
    gitignore_claude_md_artifacts "$target"
  elif [ -f "$claude_md" ]; then
    log "Migrating .claude/CLAUDE.md from copy to symlink..."
    if [ -e "$claude_md.backup" ]; then
      warn "Skipped backup (.claude/CLAUDE.md.backup already exists) — existing backup preserved"
    else
      cp "$claude_md" "$claude_md.backup"
    fi
    rm "$claude_md"
    ln -sfn "$SDD_HOME/.claude/CLAUDE.md" "$claude_md"
    ok "Migrated CLAUDE.md → symlink (backup at .claude/CLAUDE.md.backup)"
    warn "Review backup for custom overrides; move them to .claude/rules/model-overrides.md"
    gitignore_claude_md_artifacts "$target"
  else
    # No CLAUDE.md present — create symlink (honors spec §Happy Path: "si falta, crear")
    ln -sfn "$SDD_HOME/.claude/CLAUDE.md" "$claude_md"
    ok "Created CLAUDE.md symlink (was absent)"
    gitignore_claude_md_artifacts "$target"
  fi

  # ── Agents: sync upstream sdd-*.md files; byte-diff decides action ──
  # (a) absent → copy in; (b) identical → skip; (c) changed → overwrite.
  # Only upstream files are iterated — project-local agents are never touched.
  if [ -d "$SDD_HOME/.claude/agents" ]; then
    mkdir -p "$target/.claude/agents"
    local added=0 updated=0 unchanged=0
    for agent_file in "$SDD_HOME/.claude/agents"/sdd-*.md; do
      [ -f "$agent_file" ] || continue
      local agent_name
      agent_name="$(basename "$agent_file")"
      local agent_dst="$target/.claude/agents/$agent_name"
      if [ ! -e "$agent_dst" ]; then
        cp "$agent_file" "$agent_dst"
        ok "Added .claude/agents/$agent_name"
        : $((added++))
      elif cmp -s "$agent_file" "$agent_dst"; then
        : $((unchanged++))
      else
        cp "$agent_file" "$agent_dst"
        ok "Updated: $agent_name"
        : $((updated++))
      fi
    done
    log "Agents: $added added, $updated updated, $unchanged unchanged"
  fi

  ok "Update complete!"
}

# ─── doctor ────────────────────────────────────────────────────────

cmd_doctor() {
  local target
  target="$(pwd)"
  local issues=0

  log "Checking SDD setup"

  # Check global core skills
  echo ""
  log "Global core (~/.claude/skills/):"
  for skill in $CORE_SKILLS; do
    if [ -d "$HOME/.claude/skills/$skill" ] || [ -L "$HOME/.claude/skills/$skill" ]; then
      ok "  $skill"
    else
      warn "  $skill — MISSING (run 'sdd init --global')"
      ((issues++))
    fi
  done

  # Check project structure
  echo ""
  log "Project ($target):"
  for dir in .claude .claude/skills .claude/rules .specify specs research docs; do
    if [ -d "$target/$dir" ]; then
      ok "  $dir/"
    else
      warn "  $dir/ — MISSING"
      ((issues++))
    fi
  done

  # Check key project files
  for file in .claude/rules/conventions.md; do
    if [ -f "$target/$file" ]; then
      ok "  $file"
    else
      warn "  $file — MISSING"
      ((issues++))
    fi
  done

  # CLAUDE.md should be a symlink (auto-updates) unless --copy install
  local claude_md="$target/.claude/CLAUDE.md"
  if [ -L "$claude_md" ] && [ -e "$claude_md" ]; then
    ok "  .claude/CLAUDE.md (symlink → auto-updates)"
  elif [ -L "$claude_md" ]; then
    warn "  .claude/CLAUDE.md is a broken symlink (target missing) — run 'sdd update' to repair"
    ((issues++))
  elif [ -f "$claude_md" ]; then
    if is_copy_install "$target"; then
      ok "  .claude/CLAUDE.md (copy — --copy install)"
    else
      warn "  .claude/CLAUDE.md is a regular file — run 'sdd update' to migrate to symlink"
      ((issues++))
    fi
  else
    warn "  .claude/CLAUDE.md — MISSING (run 'sdd update' to create symlink)"
    ((issues++))
  fi

  # Warn if CLAUDE.md is git-tracked (absolute symlinks don't port across team machines)
  if [ -e "$claude_md" ] && (cd "$target" && git ls-files --error-unmatch .claude/CLAUDE.md &>/dev/null); then
    if [ -f "$target/.gitignore" ] && grep -Fxq ".claude/CLAUDE.md" "$target/.gitignore"; then
      warn "  .claude/CLAUDE.md is in .gitignore but still tracked — run: git rm --cached .claude/CLAUDE.md && git commit"
    else
      warn "  .claude/CLAUDE.md is tracked in git — add to .gitignore AND run: git rm --cached .claude/CLAUDE.md && git commit"
    fi
    ((issues++))
  fi

  # Check architecture-map
  local arch_file="$target/.claude/skills/architecture-map/SKILL.md"
  if [ -f "$arch_file" ]; then
    if grep -q "TODO" "$arch_file" 2>/dev/null; then
      warn "  architecture-map has TODOs — run /init-project"
      ((issues++))
    else
      ok "  architecture-map (populated)"
    fi
  else
    warn "  architecture-map — MISSING"
    ((issues++))
  fi

  # Check project-specific skills
  echo ""
  log "Project skills (.claude/skills/):"
  local project_skills=0
  for skill_dir in "$target/.claude/skills"/*/; do
    [ ! -d "$skill_dir" ] && continue
    local skill_name
    skill_name="$(basename "$skill_dir")"
    # Skip core skills and architecture-map
    if is_core_skill "$skill_name" || [ "$skill_name" = "architecture-map" ]; then
      continue
    fi
    local skill_file="$skill_dir/SKILL.md"
    if [ -f "$skill_file" ]; then
      # Check for applies-to frontmatter
      if grep -q "applies-to:" "$skill_file" 2>/dev/null; then
        local applies_to
        applies_to=$(grep "applies-to:" "$skill_file" | head -1 | sed 's/.*applies-to: *//')
        ok "  $skill_name → $applies_to"
      else
        log "  $skill_name → implement-task, review-feature (default)"
      fi
      ((project_skills++))
    fi
  done
  if [ "$project_skills" -eq 0 ]; then
    log "  (none — add project skills to .claude/skills/)"
  fi

  # Check skill registry
  echo ""
  log "Skill registry:"
  local registry_file="$target/.claude/skills/skill-registry.md"
  if [ -f "$registry_file" ]; then
    local registry_skills
    registry_skills=$(grep -c "^### " "$registry_file" 2>/dev/null || echo "0")
    ok "  skill-registry.md ($registry_skills compact rule sets)"
    if [ "$project_skills" -gt 0 ] && [ "$registry_skills" -lt "$project_skills" ]; then
      warn "  Registry has fewer skills than installed — run /build-registry"
      ((issues++))
    fi
  else
    if [ "$project_skills" -gt 0 ]; then
      warn "  skill-registry.md — MISSING (run /build-registry to generate)"
      ((issues++))
    else
      log "  (no project skills installed, registry not needed)"
    fi
  fi

  # Check Engram
  echo ""
  log "Engram:"
  if command -v engram &>/dev/null; then
    ok "  engram binary: $(engram version 2>/dev/null || echo 'installed')"
    if [ -f "$HOME/.engram/engram.db" ]; then
      ok "  database: ~/.engram/engram.db"
    else
      warn "  database not found — run 'engram setup claude-code'"
      ((issues++))
    fi
  else
    warn "  engram not installed — run 'brew install gentleman-programming/tap/engram'"
    ((issues++))
  fi

  echo ""
  if [ "$issues" -eq 0 ]; then
    ok "All checks passed!"
  else
    warn "$issues issue(s) found"
  fi
}

# ─── base-branch ───────────────────────────────────────────────────

cmd_base_branch() {
  local feature_id="${1:-}"

  # ── Layer 1: per-feature sidecar (only when feature-id supplied) ──
  if [ -n "$feature_id" ]; then
    local sidecar="specs/${feature_id}/.parent-branch"
    if [ -f "$sidecar" ]; then
      # Read first line only; strip leading/trailing whitespace
      local ref
      ref="$(head -n1 "$sidecar" | tr -d '[:space:]')"
      if [ -n "$ref" ]; then
        # Non-empty after trim — must resolve
        if git rev-parse --verify "$ref" >/dev/null 2>&1; then
          printf '%s\n' "$ref"
          return 0
        else
          printf 'error: %s references missing branch "%s"\n' "$sidecar" "$ref" >&2
          return 2
        fi
      fi
      # Empty/whitespace sidecar — fall through to Layer 2
    fi
  fi

  # ── Layer 2: project config in .claude/rules/git.md ──────────────
  local git_md=".claude/rules/git.md"
  if [ -f "$git_md" ]; then
    local config_ref
    config_ref="$(grep -m1 '^base-branch:[[:space:]]*' "$git_md" 2>/dev/null | sed 's/^base-branch:[[:space:]]*//' | tr -d '[:space:]' || true)"
    if [ -n "$config_ref" ]; then
      if git rev-parse --verify "$config_ref" >/dev/null 2>&1; then
        printf '%s\n' "$config_ref"
        return 0
      else
        printf 'error: git.md base-branch "%s" does not exist locally\n' "$config_ref" >&2
        return 2
      fi
    fi
  fi

  # ── Layer 3: auto-detect (develop → main → master, smallest count wins) ──
  local best_ref=""
  local best_count=""
  for candidate in develop main master; do
    if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
      local count
      count="$(git rev-list --count "${candidate}..HEAD" 2>/dev/null || true)"
      if [ -z "$best_ref" ] || [ "$count" -lt "$best_count" ]; then
        best_ref="$candidate"
        best_count="$count"
      fi
    fi
  done

  if [ -n "$best_ref" ]; then
    printf '%s\n' "$best_ref"
    return 0
  fi

  printf 'error: no base branch resolvable — set "base-branch:" in .claude/rules/git.md or create specs/<feature-id>/.parent-branch\n' >&2
  return 3
}

# ─── status ────────────────────────────────────────────────────────

cmd_status() {
  local feature_id="${1:-}"

  # ── Task 2: Feature-id resolution ──────────────────────────────
  if [ -z "$feature_id" ]; then
    local branch
    branch="$(git branch --show-current 2>/dev/null || true)"
    if [[ "$branch" =~ ^feature/([0-9]{3}-.+)$ ]]; then
      feature_id="${BASH_REMATCH[1]}"
    else
      printf 'error: not on a feature branch\n' >&2
      exit 1
    fi
  fi

  # ── Task 3: Folder lookup ───────────────────────────────────────
  local specs_dir
  specs_dir="$(pwd)/specs"

  local feature_dir=""
  local is_archived=false

  if [ -d "$specs_dir/$feature_id" ]; then
    feature_dir="$specs_dir/$feature_id"
  else
    # Scan specs/archive/ for *-<feature_id>
    local archive_match
    archive_match="$(find "$specs_dir/archive" -maxdepth 1 -type d -name "*-${feature_id}" 2>/dev/null | head -1)"
    if [ -n "$archive_match" ]; then
      feature_dir="$archive_match"
      is_archived=true
    fi
  fi

  if [ -z "$feature_dir" ]; then
    printf 'error: feature not found: %s\n' "$feature_id" >&2
    exit 1
  fi

  # ── Task 4: Phase detection ─────────────────────────────────────
  local phase

  if $is_archived; then
    phase="archived"
  elif [ ! -f "$feature_dir/spec.md" ] && [ ! -f "$feature_dir/quick-spec.md" ]; then
    phase="missing"
  elif [ ! -f "$feature_dir/plan.md" ] || [ ! -f "$feature_dir/tasks.md" ]; then
    # Check if fast-lane (quick-spec.md present without plan.md/tasks.md is OK)
    if [ -f "$feature_dir/quick-spec.md" ]; then
      # Fast-lane: use quick-spec.md for tasks — fall through to task counting below
      phase=""  # determined after task counting
    else
      phase="spec"
    fi
  else
    phase=""  # determined after task counting
  fi

  # ── Task 5: Task counting ───────────────────────────────────────
  local tasks_done=0
  local tasks_remaining=0
  local tasks_total=0

  if [ -z "$phase" ] || [ "$phase" = "" ]; then
    # Determine task file
    local task_file=""
    if [ -f "$feature_dir/tasks.md" ]; then
      task_file="$feature_dir/tasks.md"
      tasks_done=$(grep -c '^\- \[x\]' "$task_file" 2>/dev/null || true)
      tasks_remaining=$(grep -c '^\- \[ \]' "$task_file" 2>/dev/null || true)
    elif [ -f "$feature_dir/quick-spec.md" ]; then
      # Fast-lane: grep only inside the ## Tasks section
      # Extract from '## Tasks' to next '##' or end of file
      local in_tasks=false
      while IFS= read -r line; do
        if [[ "$line" =~ ^##[[:space:]]Tasks ]]; then
          in_tasks=true
          continue
        fi
        if $in_tasks && [[ "$line" =~ ^## ]]; then
          break
        fi
        if $in_tasks; then
          if [[ "$line" =~ ^\-[[:space:]]\[x\] ]]; then
            ((tasks_done++)) || true
          elif [[ "$line" =~ ^\-[[:space:]]\[[[:space:]]\] ]]; then
            ((tasks_remaining++)) || true
          fi
        fi
      done < "$feature_dir/quick-spec.md"
    fi
    tasks_total=$((tasks_done + tasks_remaining))

    # ── Task 6: Sentinel freshness ────────────────────────────────
    local sentinel_fresh=false
    local sentinel_file="$feature_dir/.simplified"
    if [ -f "$sentinel_file" ]; then
      local current_head
      current_head="$(git rev-parse HEAD 2>/dev/null || true)"
      if [ -n "$current_head" ] && grep -q "^git-head: ${current_head}$" "$sentinel_file" 2>/dev/null; then
        sentinel_fresh=true
      fi
    fi

    # Now determine phase based on task counts + sentinel
    if [ "$tasks_total" -eq 0 ]; then
      # No tasks found — treat as planned (empty tasks file)
      phase="planned"
    elif [ "$tasks_remaining" -eq "$tasks_total" ]; then
      phase="planned"
    elif [ "$tasks_remaining" -gt 0 ]; then
      phase="implementing"
    elif $sentinel_fresh; then
      phase="ready-to-review"
    else
      phase="ready-to-simplify"
    fi
  else
    # Phase already determined (archived, missing, spec); set sentinel and counts
    local sentinel_fresh=false
    tasks_total=0
    tasks_remaining=0
  fi

  # ── Blockers array ──────────────────────────────────────────────
  local blockers='[]'

  # ── Next command ────────────────────────────────────────────────
  local next_command
  case "$phase" in
    missing)           next_command="/sdd-new" ;;
    spec)              next_command="/plan-feature ${feature_id}" ;;
    planned)           next_command="/implement-task ${feature_id}" ;;
    implementing)      next_command="/implement-task ${feature_id}" ;;
    ready-to-simplify) next_command="/simplify-code ${feature_id}" ;;
    ready-to-review)   next_command="/review-feature ${feature_id}" ;;
    archived)          next_command="(none — feature archived)" ;;
    *)                 next_command="(unknown)" ;;
  esac

  # ── Task 7: JSON emission ───────────────────────────────────────
  # Normalise sentinel_fresh to JSON boolean
  local sentinel_json="false"
  if ${sentinel_fresh:-false}; then
    sentinel_json="true"
  fi

  printf '{\n'
  printf '  "feature_id": "%s",\n' "$feature_id"
  printf '  "phase": "%s",\n' "$phase"
  printf '  "tasks_total": %d,\n' "$tasks_total"
  printf '  "tasks_remaining": %d,\n' "$tasks_remaining"
  printf '  "sentinel_fresh": %s,\n' "$sentinel_json"
  printf '  "blockers": %s,\n' "$blockers"
  printf '  "next_command": "%s"\n' "$next_command"
  printf '}\n'
  exit 0
}

# ─── main ──────────────────────────────────────────────────────────

case "${1:-help}" in
  init)         shift; cmd_init "$@" ;;
  update)       cmd_update ;;
  doctor)       cmd_doctor ;;
  base-branch)  shift; cmd_base_branch "$@" ;;
  status)       shift; cmd_status "$@" ;;
  help|--help|-h) usage ;;
  version|--version|-v) echo "sdd v${VERSION}" ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
