#!/usr/bin/env bash
set -euo pipefail

# SDD — Spec Driven Development CLI
# Initializes any project with the SDD workflow for Claude Code.

SDD_HOME="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")/.." && pwd)"
VERSION="1.0.0"

usage() {
  cat <<EOF
sdd — Spec Driven Development CLI (v${VERSION})

Usage:
  sdd init [--copy]    Initialize SDD in the current directory
  sdd update           Re-sync symlinked skills and templates
  sdd doctor           Verify SDD setup is healthy
  sdd help             Show this help

Options for 'init':
  --copy    Copy files instead of symlinking (standalone, no auto-updates)

After 'sdd init', start Claude Code and run /init-project to auto-generate
architecture docs and detect project conventions.
EOF
}

# ─── helpers ───────────────────────────────────────────────────────

log()  { printf "\033[0;34m▸\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m✔\033[0m %s\n" "$*"; }
warn() { printf "\033[0;33m⚠\033[0m %s\n" "$*"; }
err()  { printf "\033[0;31m✖\033[0m %s\n" "$*" >&2; }

link_or_copy() {
  local src="$1" dst="$2" mode="${3:-link}"
  mkdir -p "$(dirname "$dst")"
  if [ "$mode" = "copy" ]; then
    cp -R "$src" "$dst"
  else
    ln -sfn "$src" "$dst"
  fi
}

# ─── init ──────────────────────────────────────────────────────────

cmd_init() {
  local mode="link"
  [[ "${1:-}" == "--copy" ]] && mode="copy"

  local target
  target="$(pwd)"

  if [ "$target" = "$SDD_HOME" ]; then
    err "Cannot init inside the SDD boilerplate repo itself."
    exit 1
  fi

  log "Initializing SDD in $target (mode: $mode)"

  # ── Skills (shared — symlink preferred) ──
  mkdir -p "$target/.claude/skills"
  for skill_dir in "$SDD_HOME/.claude/skills"/*/; do
    local skill_name
    skill_name="$(basename "$skill_dir")"
    link_or_copy "$skill_dir" "$target/.claude/skills/$skill_name" "$mode"
  done
  ok "Skills installed ($(ls -1 "$SDD_HOME/.claude/skills" | wc -l | tr -d ' ') skills)"

  # ── Templates (shared — symlink preferred) ──
  mkdir -p "$target/.specify"
  link_or_copy "$SDD_HOME/.specify/templates" "$target/.specify/templates" "$mode"
  ok "Templates installed"

  # ── Scripts (shared) ──
  link_or_copy "$SDD_HOME/.specify/scripts" "$target/.specify/scripts" "$mode"
  ok "Scripts installed"

  # ── Rules (project-specific — always copy, never overwrite existing) ──
  mkdir -p "$target/.claude/rules"
  for rule_file in "$SDD_HOME/.claude/rules"/*.md; do
    local rule_name
    rule_name="$(basename "$rule_file")"
    if [ -f "$target/.claude/rules/$rule_name" ]; then
      warn "Skipped .claude/rules/$rule_name (already exists)"
    else
      cp "$rule_file" "$target/.claude/rules/$rule_name"
      ok "Created .claude/rules/$rule_name"
    fi
  done

  # ── CLAUDE.md (project-specific — never overwrite) ──
  if [ -f "$target/.claude/CLAUDE.md" ]; then
    warn "Skipped .claude/CLAUDE.md (already exists)"
  else
    cp "$SDD_HOME/.claude/CLAUDE.md" "$target/.claude/CLAUDE.md"
    ok "Created .claude/CLAUDE.md"
  fi

  # ── settings.local.json (never overwrite) ──
  if [ -f "$target/.claude/settings.local.json" ]; then
    warn "Skipped .claude/settings.local.json (already exists)"
  else
    cp "$SDD_HOME/.claude/settings.local.json" "$target/.claude/settings.local.json"
    ok "Created .claude/settings.local.json"
  fi

  # ── Directory structure ──
  mkdir -p "$target/specs" "$target/research" "$target/docs/adr" "$target/docs/architecture"
  ok "Created specs/, research/, docs/adr/, docs/architecture/"

  echo ""
  ok "SDD initialized!"
  echo ""
  log "Next steps:"
  echo "  1. Open Claude Code in $target"
  echo "  2. Run /init-project to auto-detect architecture and conventions"
  echo "  3. Customize .claude/rules/ for your project"
  echo "  4. Start working: /new-feature \"your idea\""
  echo ""
  if [ "$mode" = "link" ]; then
    log "Skills and templates are symlinked to $SDD_HOME"
    log "Run 'sdd update' after pulling new versions of the SDD repo"
  fi
}

# ─── update ────────────────────────────────────────────────────────

cmd_update() {
  local target
  target="$(pwd)"

  if [ ! -d "$target/.claude/skills" ]; then
    err "No SDD setup found in $target. Run 'sdd init' first."
    exit 1
  fi

  log "Updating SDD in $target"

  # Re-sync skills
  for skill_dir in "$SDD_HOME/.claude/skills"/*/; do
    local skill_name
    skill_name="$(basename "$skill_dir")"
    local target_skill="$target/.claude/skills/$skill_name"
    if [ -L "$target_skill" ]; then
      ln -sfn "$skill_dir" "$target_skill"
      ok "Updated skill: $skill_name"
    elif [ -d "$target_skill" ]; then
      warn "Skipped $skill_name (not a symlink — was copied with --copy)"
    else
      ln -sfn "$skill_dir" "$target_skill"
      ok "Added new skill: $skill_name"
    fi
  done

  # Re-sync templates
  if [ -L "$target/.specify/templates" ]; then
    ln -sfn "$SDD_HOME/.specify/templates" "$target/.specify/templates"
    ok "Updated templates"
  else
    warn "Skipped templates (not a symlink)"
  fi

  ok "Update complete!"
}

# ─── doctor ────────────────────────────────────────────────────────

cmd_doctor() {
  local target
  target="$(pwd)"
  local issues=0

  log "Checking SDD setup in $target"

  # Check structure
  for dir in .claude .claude/skills .claude/rules .specify specs research docs; do
    if [ -d "$target/$dir" ]; then
      ok "$dir/ exists"
    else
      warn "$dir/ missing"
      ((issues++))
    fi
  done

  # Check key files
  for file in .claude/CLAUDE.md .claude/rules/conventions.md; do
    if [ -f "$target/$file" ]; then
      ok "$file exists"
    else
      warn "$file missing"
      ((issues++))
    fi
  done

  # Check skills
  local expected_skills="new-feature plan-feature implement-task research-spike review-feature archive-feature architecture-map init-project"
  for skill in $expected_skills; do
    if [ -d "$target/.claude/skills/$skill" ] || [ -L "$target/.claude/skills/$skill" ]; then
      ok "Skill: $skill"
    else
      warn "Skill missing: $skill"
      ((issues++))
    fi
  done

  # Check if architecture-map has been generated
  local arch_file="$target/.claude/skills/architecture-map/SKILL.md"
  if [ -f "$arch_file" ] || [ -L "$arch_file" ]; then
    if grep -q "TODO" "$arch_file" 2>/dev/null; then
      warn "architecture-map has TODO placeholders — run /init-project"
      ((issues++))
    fi
  fi

  echo ""
  if [ "$issues" -eq 0 ]; then
    ok "All checks passed!"
  else
    warn "$issues issue(s) found"
  fi
}

# ─── main ──────────────────────────────────────────────────────────

case "${1:-help}" in
  init)   shift; cmd_init "$@" ;;
  update) cmd_update ;;
  doctor) cmd_doctor ;;
  help|--help|-h) usage ;;
  version|--version|-v) echo "sdd v${VERSION}" ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
